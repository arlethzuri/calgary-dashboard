# Base directory that contains:
# - data/            (raw snapshots by source/date)
# - processed_data/  (cleaned outputs by source/date)
#
# If unset, defaults to ./data/calgary relative to repo root.
DATA_ROOT=

# Token created from data.calgary.ca account settings.
OPEN_CALGARY_APP_TOKEN=YOUR_OPEN_CALGARY_APP_TOKEN

# Neo4j connection settings.
NEO4J_URI=neo4j://localhost
NEO4J_USER=neo4j
NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD
NEO4J_DATABASE=neo4j
